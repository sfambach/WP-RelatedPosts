{
    "$schema": "https://wp.org",
    "apiVersion": 3,
    "name": "fambach/related-posts",
    "title": "Related Posts",
    "category": "widgets",
    "icon": "list-view",
    "description": "Zeigt verwandte Beiträge basierend auf Kategorien an.",
    "attributes": {
        "beitraege_aktivieren": {
            "type": "boolean",
            "default": true
        },
        "anzahl_beitraege": {
            "type": "integer",
            "default": 5
        },
        "ueberschrift_typ": {
            "type": "string",
            "default": "h3"
        }
    },
    "supports": {
        "align": true
    }
}
